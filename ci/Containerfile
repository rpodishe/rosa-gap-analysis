# CI build-root image for gap-analysis
# Used by ci-operator via build_root.project_image.dockerfile_path
# Tools are layer-cached — installs only re-run when this file changes

FROM registry.access.redhat.com/ubi9/ubi:latest

ARG OC_VERSION=4.21
ARG YQ_VERSION=v4.52.4
ARG OCM_CLI_BASE_URL="https://github.com/openshift-online/ocm-cli/releases/latest/download"
ARG ROSA_CLI_BASE_URL="https://github.com/openshift/rosa/releases/latest/download"

# System packages
RUN dnf install --allowerasing -y \
        git \
        make \
        bash \
        jq \
        curl \
        wget \
        python3 \
        python3-pip \
        python3-pyyaml \
        findutils \
        diffutils \
        coreutils \
    && dnf clean all

# Install Python packages
RUN pip3 install --no-cache-dir Jinja2>=3.1.0

# Install yq (YAML processor - recommended for parsing CredentialsRequests)
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  YQ_ARCH="amd64" ;; \
    esac && \
    curl -fsSL "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_${YQ_ARCH}" -o /usr/local/bin/yq && \
    chmod +x /usr/local/bin/yq && \
    yq --version

# Install gh CLI (GitHub CLI - required for PR link detection in warnings)
RUN dnf install -y 'dnf-command(config-manager)' && \
    dnf config-manager --add-repo https://cli.github.com/packages/rpm/gh-cli.repo && \
    dnf install -y gh && \
    dnf clean all && \
    gh --version

# Install oc CLI (OpenShift client - required for 'oc adm release extract')
RUN curl -fsSL "https://mirror.openshift.com/pub/openshift-v4/clients/ocp/stable-${OC_VERSION}/openshift-client-linux.tar.gz" -o /tmp/oc.tar.gz && \
    tar -xzf /tmp/oc.tar.gz -C /usr/local/bin oc kubectl && \
    chmod +x /usr/local/bin/oc /usr/local/bin/kubectl && \
    rm -f /tmp/oc.tar.gz && \
    oc version --client

# Install ocm-cli 
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  arch="amd64" ;; \
        aarch64) arch="arm64" ;; \
    esac && \
    curl -fsSL "${OCM_CLI_BASE_URL}/ocm-linux-${arch}" -o /usr/local/bin/ocm && \
    chmod +x /usr/local/bin/ocm && \
    ocm version

# Install rosa-cli 
RUN arch=$(uname -m) && \
    case "${arch}" in \
        x86_64)  arch="x86_64" ;; \
        aarch64) arch="arm64" ;; \
    esac && \
    curl -fsSL "${ROSA_CLI_BASE_URL}/rosa_Linux_${arch}.tar.gz" -o /tmp/rosa.tar.gz && \
    tar -xzf /tmp/rosa.tar.gz -C /usr/local/bin rosa && \
    chmod +x /usr/local/bin/rosa && \
    rosa version


# Pre-create cache directories writable by any UID (OpenShift runs as random UID)
RUN mkdir -p /tmp/.cache /tmp/gap-analysis-data && \
    chmod -R 777 /tmp/.cache /tmp/gap-analysis-data

ENV HOME=/tmp
ENV XDG_CACHE_HOME=/tmp/.cache

# Set working directory for gap analysis scripts
WORKDIR /gap-analysis

# Copy gap analysis scripts into the image (preserves permissions)
COPY scripts/ /gap-analysis/scripts/

# Add scripts to PATH for convenience
ENV PATH="/gap-analysis/scripts:/gap-analysis/scripts/lib:${PATH}"

# Verify all required tools are installed
RUN echo "Verifying tool installations..." && \
    bash --version && \
    jq --version && \
    yq --version && \
    gh --version && \
    oc version --client && \
    echo "ocm: " && ocm version && \
    echo "rosa: " && rosa version && \
    python3 --version && \
    python3 -c "import yaml; print('PyYAML available')" && \
    python3 -c "import jinja2; print('Jinja2 available')" && \
    echo "All tools verified successfully"
